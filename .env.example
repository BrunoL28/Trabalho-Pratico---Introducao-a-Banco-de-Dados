# Copie para .env (ou exporte no shell) e ajuste conforme o ambiente.
#
# A aplicação lê DATABASE_URL; se o arquivo .env não existir, o default em
# src/config.py já aponta para o Postgres local do docker-compose.

# --- Desenvolvimento local (docker compose up -d) ---------------------------
# Casa com as credenciais do docker-compose.yml. Pode deixar comentado: é o
# default do projeto.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pix_med

# --- Produção (Supabase) ----------------------------------------------------
# Em rede IPv4 (ex.: WSL2): use o host do *Session Pooler*
# (Connect -> Session pooler), não o host direto db.<ref>.supabase.co.
# DATABASE_URL=postgresql+psycopg2://postgres.<ref>:SENHA@aws-1-<regiao>.pooler.supabase.com:5432/postgres
